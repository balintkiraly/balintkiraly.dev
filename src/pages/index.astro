---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog', ({ data }) => {
  return data.hidden !== true;
})).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const posts = allPosts.slice(0, 3);
const hasMorePosts = allPosts.length > 3;

const allProjects = (await getCollection('projects', ({ data }) => {
  return data.hidden !== true;
}));
const projects = allProjects.slice(0, 3);
const hasMoreProjects = allProjects.length > 3;
---

<BaseLayout title="My Blog">
  <section class="mb-16">
    <h1 class="text-3xl font-mono font-bold mb-4 tracking-tight">
      <span class="text-amber-600 dark:text-amber-500">&gt;</span> Hello
    </h1>
    <p class="text-neutral-600 dark:text-neutral-400 font-mono text-lg mb-6">
      Senior Full Stack Engineer sharing thoughts on code and building things.
    </p>
    <a href="/about" class="inline-flex items-center gap-2 text-sm font-mono px-4 py-2 bg-amber-600 text-white dark:bg-amber-500 dark:text-neutral-950 hover:bg-amber-700 dark:hover:bg-amber-400 transition-colors">
      Learn more about me <span>-&gt;</span>
    </a>
  </section>

  <section>
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-sm font-mono text-neutral-500 uppercase tracking-widest">
        -- Latest Posts
      </h2>
      {hasMorePosts && (
        <a href="/blog" class="text-sm font-mono text-amber-600 dark:text-amber-500 hover:underline">
          [view all]
        </a>
      )}
    </div>
    
    {posts.length > 0 ? (
      <ul class="space-y-3">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}`} class="block group">
              <article class="p-4 border border-neutral-200 dark:border-neutral-800 hover:border-amber-500/50 hover:bg-amber-500/5 dark:hover:bg-amber-500/5 transition-all duration-150">
                <div class="flex items-baseline justify-between gap-4 mb-2">
                  <h2 class="text-lg font-mono font-semibold group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">
                    {post.data.title}
                  </h2>
                  <time class="text-xs font-mono text-neutral-500 shrink-0">
                    [{post.data.pubDate.toLocaleDateString('en-US', {
                      year: '2-digit',
                      month: '2-digit',
                      day: '2-digit',
                    })}]
                  </time>
                </div>
                <p class="text-neutral-500 dark:text-neutral-500 font-mono text-sm mb-3">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="text-xs font-mono px-2 py-0.5 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
              </article>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="text-center py-12 border border-neutral-200 dark:border-neutral-800">
        <p class="text-neutral-500 font-mono">No posts yet. Coming soon!</p>
      </div>
    )}
  </section>

  <section class="mt-16">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-sm font-mono text-neutral-500 uppercase tracking-widest">
        -- Projects
      </h2>
      {hasMoreProjects && (
        <a href="/projects" class="text-sm font-mono text-amber-600 dark:text-amber-500 hover:underline">
          [view all]
        </a>
      )}
    </div>
    
    {projects.length > 0 ? (
      <ul class="space-y-3">
        {projects.map((project) => (
          <li>
            <a href={`/projects/${project.slug}`} class="block group">
              <article class="p-4 border border-neutral-200 dark:border-neutral-800 hover:border-amber-500/50 hover:bg-amber-500/5 dark:hover:bg-amber-500/5 transition-all duration-150">
                <div class="flex items-baseline justify-between gap-4 mb-2">
                  <h2 class="text-lg font-mono font-semibold group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors">
                    {project.data.title}
                  </h2>
                  <div class="flex gap-3 shrink-0">
                    {project.data.github && (
                      <a 
                        href={project.data.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-neutral-500 hover:text-amber-600 dark:hover:text-amber-400 transition-colors"
                        aria-label="GitHub"
                        onclick={(e) => e.stopPropagation()}
                      >
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
                        </svg>
                      </a>
                    )}
                    {project.data.live && (
                      <a 
                        href={project.data.live}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-neutral-500 hover:text-amber-600 dark:hover:text-amber-400 transition-colors"
                        aria-label="Live"
                        onclick={(e) => e.stopPropagation()}
                      >
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
                <p class="text-neutral-500 dark:text-neutral-500 font-mono text-sm mb-3">{project.data.description}</p>
                {project.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {project.data.tags.map((tag) => (
                      <span class="text-xs font-mono px-2 py-0.5 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
              </article>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="text-center py-12 border border-neutral-200 dark:border-neutral-800">
        <p class="text-neutral-500 font-mono">No projects yet. Coming soon!</p>
      </div>
    )}
  </section>
</BaseLayout>
