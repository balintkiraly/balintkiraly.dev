---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => {
    return data.hidden !== true;
  });
  if (projects.length === 0) return [];
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}

const project = Astro.props;
if (!project) return Astro.redirect('/projects');
const { Content } = await project.render();
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <article>
    <header class="mb-10">
      <a href="/projects" class="inline-flex items-center text-sm text-neutral-500 hover:text-amber-600 dark:hover:text-amber-400 transition-colors mb-6">
        &lt;- back
      </a>
      
      <div class="aspect-video bg-neutral-100 dark:bg-neutral-900 mb-6 overflow-hidden border border-neutral-200 dark:border-neutral-800">
        <img 
          src={project.data.image} 
          alt={project.data.title}
          class="w-full h-full object-cover"
        />
      </div>
      
      <h1 class="text-2xl font-bold mb-3">{project.data.title}</h1>
      <p class="text-neutral-600 dark:text-neutral-400 mb-4">{project.data.description}</p>
      
      <div class="flex flex-wrap gap-2 mb-6">
        {project.data.tags.map((tag) => (
          <span class="text-xs font-mono px-2 py-0.5 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">
            #{tag}
          </span>
        ))}
      </div>
      
      <div class="flex gap-4">
        {project.data.github && (
          <a 
            href={project.data.github}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 bg-amber-600 hover:bg-amber-700 text-white font-mono text-sm transition-colors"
          >
            <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
            View on GitHub
          </a>
        )}
        {project.data.live && (
          <a 
            href={project.data.live}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 border border-neutral-300 dark:border-neutral-700 hover:border-amber-500 font-mono text-sm transition-colors"
          >
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Live Demo
          </a>
        )}
      </div>
    </header>

    <div class="prose prose-neutral dark:prose-invert prose-neutral font-mono max-w-none 
      prose-headings:font-bold
      dark:prose-headings:text-neutral-200 prose-headings:text-neutral-900
      prose-a:text-amber-600 dark:prose-a:text-amber-400 prose-a:no-underline hover:prose-a:text-amber-500 dark:hover:prose-a:text-amber-300
      prose-code:text-amber-600 dark:prose-code:text-amber-300 prose-code:bg-neutral-100 dark:prose-code:bg-neutral-900 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none
      dark:prose-pre:bg-neutral-900 prose-pre:bg-neutral-100 dark:prose-pre:border-amber-500/30 prose-pre:border-neutral-200 prose-pre:rounded-none prose-pre:p-0 prose-pre:my-6
      dark:prose-blockquote:border-l-amber-500 prose-blockquote:border-l-amber-600 dark:prose-blockquote:text-neutral-400 prose-blockquote:text-neutral-600
      dark:prose-li:marker:text-amber-500 prose-li:marker:text-amber-600 dark:prose-li:text-neutral-300 prose-li:text-neutral-700
      dark:prose-strong:text-neutral-200 prose-strong:text-neutral-800
      dark:prose-p:text-neutral-300 prose-p:text-neutral-700
      prose-pre:text-sm">
      <Content />
    </div>

    <style is:global>
      .dark .astro-code {
        background-color: #0a0a0a !important;
        border: 1px solid rgba(245, 158, 11, 0.2);
        color: #e5e5e5;
      }
      
      .astro-code {
        background-color: #f5f5f5 !important;
        border: 1px solid rgba(217, 119, 6, 0.2);
        padding: 1.25rem !important;
        border-radius: 0;
        position: relative;
        overflow-x: auto;
        color: #1a1a1a;
      }
      
      .dark .astro-code::before {
        content: '> code';
        display: block;
        font-size: 0.7rem;
        color: #fbbf24;
        border-bottom: 1px solid rgba(245, 158, 11, 0.3);
        padding-bottom: 0.5rem;
        margin-bottom: 0.75rem;
      }

      .astro-code::before {
        content: '> code';
        display: block;
        font-size: 0.7rem;
        color: #d97706;
        border-bottom: 1px solid rgba(217, 119, 6, 0.3);
        padding-bottom: 0.5rem;
        margin-bottom: 0.75rem;
      }

      .astro-code code {
        background: transparent !important;
        padding: 0 !important;
      }

      .astro-code code::before,
      .astro-code code::after {
        content: none !important;
      }
    </style>
  </article>
</BaseLayout>
