---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <section class="mb-12">
    <h1 class="text-3xl font-mono font-bold mb-6 tracking-tight">
      <span class="text-amber-600 dark:text-amber-500">&gt;</span> About
    </h1>
    
    <div class="space-y-6 text-neutral-600 dark:text-neutral-400 font-mono">
      <p class="text-lg text-neutral-800 dark:text-neutral-300 leading-relaxed">
        Hi, I'm <span class="text-amber-600 dark:text-amber-500">Bálint Király</span>. I'm a Senior Full Stack Engineer based in the countryside of Hungary.
      </p>
      
      <p>
        With more than 9 years of experience in software development, I have a strong passion for building 
        great products and solving complex problems. I started my journey in the industry at a young age 
        and have been actively working in the field ever since.
      </p>
      
      <p>
        Currently seeking new opportunities to challenge myself and further advance my skills.
      </p>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-sm font-mono text-neutral-500 uppercase tracking-widest mb-6">
      -- Contact
    </h2>
    
    <div class="space-y-2 font-mono text-sm">
      <p>
        <span class="text-amber-600 dark:text-amber-500">email:</span> 
        <a href="mailto:hello@balintkiraly.dev" class="text-neutral-700 dark:text-neutral-300 hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
          hello@balintkiraly.dev
        </a>
      </p>
      <p>
        <span class="text-amber-600 dark:text-amber-500">github:</span> 
        <a href="https://github.com/balintkiraly" target="_blank" class="text-neutral-700 dark:text-neutral-300 hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
          @balintkiraly
        </a>
      </p>
      <p>
        <span class="text-amber-600 dark:text-amber-500">linkedin:</span> 
        <a href="https://linkedin.com/in/kiralybalint" target="_blank" class="text-neutral-700 dark:text-neutral-300 hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
          /in/kiralybalint
        </a>
      </p>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-sm font-mono text-neutral-500 uppercase tracking-widest mb-6">
      -- Tech I Love
    </h2>
    
    <div class="flex flex-wrap gap-2 font-mono text-sm">
      <span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">TypeScript</span>
      <span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">React</span>
      <span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">Next.js</span>
      <span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">Remix</span>
      <span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">Node.js</span>
      <span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">PostgreSQL</span>
      <span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">GraphQL</span>
      <span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">Prisma</span>
      <span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">Docker</span>
      <span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">AWS</span>
      <span class="px-2 py-1 bg-neutral-100 dark:bg-neutral-900 text-neutral-600 dark:text-neutral-400 border border-neutral-200 dark:border-neutral-800">TailwindCSS</span>
    </div>
  </section>

  <section class="pt-8 border-t border-neutral-200 dark:border-neutral-800">
    <h2 class="text-sm font-mono text-neutral-500 uppercase tracking-widest mb-8">
      -- Experience
    </h2>
    
    <div class="space-y-8">
      <div class="relative pl-6 border-l border-neutral-200 dark:border-neutral-800">
        <div class="absolute -left-1 top-1 w-2 h-2 rounded-full bg-amber-500"></div>
        <div class="mb-1">
          <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Senior/Lead Software Engineer</h3>
          <p class="text-neutral-500 text-sm">QuartzDevs • Remote • Mar 2024 - Dec 2025</p>
        </div>
        <p class="text-neutral-600 dark:text-neutral-500 text-sm mt-2">
          Developed B2B e-commerce webshops and led projects from landing pages to complex AI-integrated applications. 
          Mentored developers and delivered high-quality solutions using TS, React, TailwindCSS, NextJS, Remix, GraphQL, Prisma.
        </p>
      </div>
      
      <div class="relative pl-6 border-l border-neutral-200 dark:border-neutral-800">
        <div class="absolute -left-1 top-1 w-2 h-2 rounded-full bg-amber-600"></div>
        <div class="mb-1">
          <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">GoStudent</h3>
          <p class="text-neutral-500 text-sm">Remote • July 2021 - Feb 2024</p>
        </div>
        <p class="text-neutral-600 dark:text-neutral-500 text-sm mt-2">
          <span class="text-amber-600 dark:text-amber-500">Product Engineering Lead (Jul 2022 - Feb 2024)</span> — Led team of 5 engineers, conducted 1:1s, provided feedback. 
          <span class="text-amber-600 dark:text-amber-500">Senior Frontend Engineer (Jul 2021 - Feb 2024)</span> — Developed new features and improved UX. Technologies: TypeScript, React, Redux, NodeJS, WebSocket, TailwindCSS.
        </p>
      </div>
      
      <div class="relative pl-6 border-l border-neutral-200 dark:border-neutral-800">
        <div class="absolute -left-1 top-1 w-2 h-2 rounded-full bg-amber-700"></div>
        <div class="mb-1">
          <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Web Software Engineer</h3>
          <p class="text-neutral-500 text-sm">BV Technologies (BetVictor) • Hybrid • July 2020 - July 2021</p>
        </div>
        <p class="text-neutral-600 dark:text-neutral-500 text-sm mt-2">
          Worked on large-scale online betting platform using React and Ruby on Rails.
        </p>
      </div>
      
      <div class="relative pl-6 border-l border-neutral-200 dark:border-neutral-800">
        <div class="absolute -left-1 top-1 w-2 h-2 rounded-full bg-amber-800"></div>
        <div class="mb-1">
          <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Full Stack Engineer</h3>
          <p class="text-neutral-500 text-sm">Cogito Technologies • Hybrid • Feb 2019 - Mar 2020</p>
        </div>
        <p class="text-neutral-600 dark:text-neutral-500 text-sm mt-2">
          Developed collaborative learning platform for university students. Deepened DevOps knowledge.
        </p>
      </div>
      
      <div class="relative pl-6 border-l border-neutral-200 dark:border-neutral-800">
        <div class="absolute -left-1 top-1 w-2 h-2 rounded-full bg-amber-900"></div>
        <div class="mb-1">
          <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Ruby on Rails Developer</h3>
          <p class="text-neutral-500 text-sm">Silio Digitális Médiaügynökség Kft. • Budapest • Dec 2018 - Apr 2019</p>
        </div>
        <p class="text-neutral-600 dark:text-neutral-500 text-sm mt-2">
          Gained experience developing full-stack web applications using Ruby on Rails and simple templating techniques.
        </p>
      </div>
      
      <div class="relative pl-6 border-l border-neutral-200 dark:border-neutral-800">
        <div class="absolute -left-1 top-1 w-2 h-2 rounded-full bg-amber-900"></div>
        <div class="mb-1">
          <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">PHP Developer</h3>
          <p class="text-neutral-500 text-sm">Innobile Informatikai Kft. • Budapest • Mar 2017 - Nov 2018</p>
        </div>
        <p class="text-neutral-600 dark:text-neutral-500 text-sm mt-2">
          Developed administration systems, including designing and implementing efficient database structures and endpoints.
        </p>
      </div>
    </div>
  </section>

  <section class="mt-12 pt-8 border-t border-neutral-200 dark:border-neutral-800">
    <h2 class="text-sm font-mono text-neutral-500 uppercase tracking-widest mb-6">
      -- Education
    </h2>
    
    <div class="space-y-4">
      <div class="relative pl-6 border-l border-neutral-200 dark:border-neutral-800">
        <div class="absolute -left-1 top-1 w-2 h-2 rounded-full bg-amber-900"></div>
        <div>
          <h3 class="text-base font-semibold text-neutral-800 dark:text-neutral-200">Computer Science</h3>
          <p class="text-neutral-500 text-sm">Budapest University of Technology and Economics • Sept 2015 - Jan 2021</p>
          <p class="text-neutral-600 dark:text-neutral-500 text-sm mt-1">Infocommunication Systems Specialisation</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
