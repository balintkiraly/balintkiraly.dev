---
interface Props {
  src: string;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="my-8">
  <img 
    src={src} 
    alt={alt}
    class="mx-auto rounded-lg shadow-lg w-full max-w-2xl border border-neutral-200 dark:border-neutral-700"
  />
  {caption && (
    <figcaption class="text-center text-sm text-neutral-500 dark:text-neutral-400 mt-3 font-mono">
      {caption}
    </figcaption>
  )}
</figure>
